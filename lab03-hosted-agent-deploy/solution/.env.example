# 로컬 실행(azd ai agent run / python main.py)용 환경 변수.
# Foundry hosted 환경에서는 플랫폼 기본값과 azure.yaml의 environmentVariables
# 매핑을 통해 주입되므로 배포 이미지에 .env를 포함하지 않습니다.

# Foundry 프로젝트 엔드포인트
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# 배포한 채팅 모델 이름
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o
